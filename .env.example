# SIAKAD Maleo Docker Compose environment
# Copy to .env before running docker compose.

POSTGRES_USER=maleo_app
POSTGRES_PASSWORD=CHANGE_ME_generate_a_strong_database_password

DATABASE_URL=postgresql://maleo_app:CHANGE_ME_generate_a_strong_database_password@db:5432/maleo

JWT_SECRET=CHANGE_ME_generate_a_strong_random_secret
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_second_strong_random_secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api
