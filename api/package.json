{
  "name": "maleo-api",
  "version": "1.0.0",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "prisma migrate deploy && prisma db seed && node dist/src/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "db:migrate": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5",
    "@types/compression": "^1.8.1",
    "bcryptjs": "^2",
    "compression": "^1.8.1",
    "cors": "^2",
    "dotenv": "^16",
    "exceljs": "^4.4.0",
    "express": "^4",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9",
    "morgan": "^1.11.0",
    "multer": "^1",
    "xlsx": "^0.18.5",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2",
    "@types/cors": "^2",
    "@types/exceljs": "^0.5.3",
    "@types/express": "^4",
    "@types/jsonwebtoken": "^9",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^1",
    "@types/node": "^20",
    "@types/supertest": "^7.2.0",
    "@vitest/ui": "^4.1.8",
    "prisma": "^5",
    "supertest": "^7.2.2",
    "ts-node": "^10",
    "ts-node-dev": "^2",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
