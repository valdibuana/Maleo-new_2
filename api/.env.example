# ============================================
# SIAKAD Maleo — Backend Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# --- Database ---
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/maleo"

# --- JWT ---
# REQUIRED: A strong random secret (min 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DO NOT use the default in production!
JWT_SECRET="CHANGE_ME_generate_a_strong_random_secret"

# Token expiry (e.g. "1h", "24h", "7d")
JWT_EXPIRES_IN="24h"

# Optional refresh token secret (recommended to be different from JWT_SECRET)
JWT_REFRESH_SECRET="CHANGE_ME_generate_a_second_strong_random_secret"

# Refresh token expiry (e.g. "7d", "30d")
JWT_REFRESH_EXPIRES_IN="30d"

# --- Server ---
# Port the Express API listens on
PORT=4000

# --- CORS ---
# Comma-separated list of allowed frontend origins
# Production example: "https://siakad.maleo.sch.id,https://www.siakad.maleo.sch.id"
CLIENT_URL="http://localhost:3000"

# --- Uploads ---
# Directory for uploaded files (relative to api/)
UPLOAD_DIR="./uploads"
